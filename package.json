{
  "name": "@fabdeh/eslint-config",
  "type": "module",
  "version": "0.10.0",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "description": "My personal eslint config preset",
  "author": {
    "name": "Fabien Dehopré",
    "email": "fabien@dehopre.dev",
    "url": "https://github.com/FabienDehopre"
  },
  "license": "MIT",
  "homepage": "https://eslint-config.dehopre.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FabienDehopre/eslint-config.git"
  },
  "bugs": "https://github.com/FabienDehopre/eslint-config/issues",
  "keywords": [
    "eslint",
    "eslintconfig",
    "eslint-config",
    "lint",
    "formatting"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm gen && tsdown",
    "build:ci": "tsdown",
    "build:inspector": "pnpm build && pnpx @eslint/config-inspector build",
    "dev": "pnpx @eslint/config-inspector --config eslint.config.ts",
    "check-exports": "attw --pack . --profile esm-only",
    "preinstall": "npx only-allow pnpm",
    "prepare": "is-ci || simple-git-hooks",
    "commit": "git-cz",
    "lint": "pnpm build && eslint . --fix",
    "lint:ci": "eslint . --quiet",
    "prepack": "pnpm build",
    "release": "bumpp",
    "typecheck": "tsc --noEmit -p tsconfig.src.json",
    "gen": "tsx scripts/typegen.ts",
    "validate-pr-title": "tsx scripts/validate-pr-title.ts",
    "test": "vitest"
  },
  "peerDependencies": {
    "eslint": "^9.38.0 || ^10.0.0",
    "eslint-plugin-better-tailwindcss": "catalog:",
    "eslint-plugin-erasable-syntax-only": "catalog:"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-better-tailwindcss": {
      "optional": true
    },
    "eslint-plugin-erasable-syntax-only": {
      "optional": true
    }
  },
  "dependencies": {
    "@antfu/install-pkg": "catalog:",
    "@clack/prompts": "catalog:",
    "@eslint-community/eslint-plugin-eslint-comments": "catalog:",
    "@eslint/markdown": "catalog:",
    "@ngrx/eslint-plugin": "catalog:",
    "@stylistic/eslint-plugin": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@typescript-eslint/utils": "catalog:",
    "@vitest/eslint-plugin": "catalog:",
    "angular-eslint": "catalog:",
    "eslint-config-flat-gitignore": "catalog:",
    "eslint-flat-config-utils": "catalog:",
    "eslint-merge-processors": "catalog:",
    "eslint-plugin-import-x": "catalog:",
    "eslint-plugin-jest-dom": "catalog:",
    "eslint-plugin-jsdoc": "catalog:",
    "eslint-plugin-jsonc": "catalog:",
    "eslint-plugin-n": "catalog:",
    "eslint-plugin-perfectionist": "catalog:",
    "eslint-plugin-playwright": "catalog:",
    "eslint-plugin-pnpm": "catalog:",
    "eslint-plugin-prefer-arrow-functions": "catalog:",
    "eslint-plugin-regexp": "catalog:",
    "eslint-plugin-testing-library": "catalog:",
    "eslint-plugin-toml": "catalog:",
    "eslint-plugin-unicorn": "catalog:",
    "eslint-plugin-unused-imports": "catalog:",
    "eslint-plugin-yml": "catalog:",
    "glob": "catalog:",
    "globals": "catalog:",
    "jsonc-eslint-parser": "catalog:",
    "local-pkg": "catalog:",
    "typescript-eslint": "catalog:",
    "yaml-eslint-parser": "catalog:"
  },
  "devDependencies": {
    "@angular/core": "catalog:",
    "@arethetypeswrong/cli": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@commitlint/cz-commitlint": "catalog:",
    "@commitlint/lint": "catalog:",
    "@commitlint/load": "catalog:",
    "@fabdeh/eslint-config": "workspace:*",
    "@ngrx/effects": "catalog:",
    "@ngrx/operators": "catalog:",
    "@ngrx/signals": "catalog:",
    "@ngrx/store": "catalog:",
    "@testing-library/angular": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@types/fs-extra": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "bumpp": "catalog:",
    "changelogithub": "catalog:",
    "commitizen": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-better-tailwindcss": "catalog:",
    "eslint-plugin-erasable-syntax-only": "catalog:",
    "eslint-typegen": "catalog:",
    "execa": "catalog:",
    "fs-extra": "catalog:",
    "is-ci": "catalog:",
    "jiti": "catalog:",
    "nano-staged": "catalog:",
    "playwright": "catalog:",
    "semver": "catalog:",
    "simple-git-hooks": "catalog:",
    "tailwindcss": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion": "^5.0.1",
      "@modelcontextprotocol/sdk": "^1.26.0",
      "lodash": "^4.17.23",
      "qs": "^6.15.0"
    }
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged",
    "commit-msg": "pnpm commitlint --edit ${1}"
  },
  "nano-staged": {
    "*": "eslint --fix"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  }
}
